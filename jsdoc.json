{
    "tags": {
        "allowUnknownTags": true
    },
    "source": {
        "include": [
            "src"
        ],
        "includePattern": ".+\\.ts$",
        "excludePattern": "(^|\/|\\\\)_"
    },
    "opts": {
        "destination": "docs/jsdoc",
        "recurse": true,
        "template": "default"
    }
}