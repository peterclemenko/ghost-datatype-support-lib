{
  "name": "ghost-datatype-support-lib",
  "version": "0.2.0",
  "description": "A template for creating npm packages using TypeScript and VSCode",
  "main": "./lib/index.js",
  "files": [
    "lib/**/*"
  ],
  "types": "lib/index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "clean": "rm -rf ./lib/",
    "cm": "cz",
    "lint": "eslint ./src/ --fix",
    "lint:ci": "eslint ./src --max-warnings 0",
    "docs": "typedoc --options typedoc.json",
    "prepare": "husky install",
    "semantic-release": "semantic-release",
    "test:watch": "jest --watch",
    "test": "jest --coverage",
    "test:mocha": "mocha -r ts-node/register \"test/**/*.mocha.spec.ts\" --recursive",
    "test:lint": "npm run lint:ci",
    "typecheck": "tsc --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/peterclemenko/ghost-datatype-support-lib.git"
  },
  "license": "MIT",
  "author": {
    "name": "Peter Clemenko",
    "email": "peterclemenko@users.noreply.github.com",
    "url": "https://github.com/peterclemenko"
  },
  "engines": {
    "node": ">=12.0"
  },
  "keywords": [
    "boilerplate",
    "template",
    "typescript",
    "vscode",
    "jest",
    "husky",
    "commitizen",
    "semantic-release",
    "codecov"
  ],
  "bugs": {
    "url": "https://github.com/peterclemenko/ghost-datatype-support-lib/issues"
  },
  "homepage": "https://github.com/peterclemenko/ghost-datatype-support-lib#readme",
  "devDependencies": {
    "@ryansonshine/commitizen": "^4.2.8",
    "@ryansonshine/cz-conventional-changelog": "^3.3.4",
    "@types/chai": "^4.3.4",
    "@types/jest": "^27.5.2",
    "@types/mocha": "^10.0.1",
    "@types/node": "^12.20.55",
    "@typescript-eslint/eslint-plugin": "^4.22.0",
    "@typescript-eslint/parser": "^4.22.0",
    "chai": "^4.3.7",
    "conventional-changelog-conventionalcommits": "^5.0.0",
    "eslint": "^7.25.0",
    "eslint-config-prettier": "^8.3.0",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-prettier": "^4.2.5",
    "husky": "^6.0.0",
    "jest": "^27.2.0",
    "jsdoc": "^4.0.2",
    "lint-staged": "^13.2.1",
    "mocha": "^10.2.0",
    "prettier": "^2.2.1",
    "semantic-release": "^21.0.1",
    "sinon": "^15.2.0",
    "ts-jest": "^27.0.5",
    "ts-node": "^10.2.1",
    "typedoc": "^0.25.0",
    "typescript": "^4.2.4"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/@ryansonshine/cz-conventional-changelog"
    }
  },
  "lint-staged": {
    "*.ts": "eslint --cache --cache-location .eslintcache --fix"
  },
  "release": {
    "branches": [
      "main"
    ],
    "plugins": [
      [
        "@semantic-release/commit-analyzer",
        {
          "preset": "conventionalcommits",
          "releaseRules": [
            {
              "type": "build",
              "scope": "deps",
              "release": "patch"
            }
          ]
        }
      ],
      [
        "@semantic-release/release-notes-generator",
        {
          "preset": "conventionalcommits",
          "presetConfig": {
            "types": [
              {
                "type": "feat",
                "section": "Features"
              },
              {
                "type": "fix",
                "section": "Bug Fixes"
              },
              {
                "type": "build",
                "section": "Dependencies and Other Build Updates",
                "hidden": false
              }
            ]
          }
        }
      ],
      "@semantic-release/npm",
      "@semantic-release/github"
    ]
  }
}
